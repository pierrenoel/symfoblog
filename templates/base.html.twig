<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        <div class="nav_design">
            <nav class="wrapper">
                <div>
                    <a href="{{ path('app_posts') }}" class="brand_title">Codeforge</a>
                </div>
                <div class="flex">
                    <a href="{{ path('app_posts') }}" class="nav_link">Home</a>
                    <div class="menuToogle">
                         <a href="{{ path('app_post_create') }}" class="nav_link">New</a>
                            <div class="toogle">
                                <a href="{{ path('app_post_create') }}" class="nav_link">Post</a>
                                <a href="{{ path('app_category_create') }}" class="nav_link">Category</a>
                            </div>
                    </div>
                   
                </div>
            </nav>    
        </div>

        {% for message in app.flashes('notice') %}
            <div class="flash">
                {{ message }}
            </div>
        {% endfor %}
       

        {% block body %}{% endblock %}
    </body>
</html>
